# API key for authentication (required)
FAST_APPLY_API_KEY=your-api-key-here

# Base URL of the OpenAI-compatible endpoint (optional)
# If not set, the tool will use the default endpoint
FAST_APPLY_ENDPOINT_URL=https://api.fireworks.ai/inference/v1

# Model name to use (optional)
# If not set, the tool will use the default model
FAST_APPLY_MODEL_NAME=fast-apply-7b
